# Copy this file to ~/.config/pi-openwebui-bridge/bridge.env
#
# The launcher loads this file automatically.
# Keep the real file outside the repository.
#
# Syntax: shell key=value pairs.

# Required
OPENWEBUI_URL=https://127.0.0.1:3000
OPENWEBUI_API_KEY=replace-with-your-openwebui-api-key

# Optional bridge settings
# PI_BRIDGE_HOST=127.0.0.1
# PI_BRIDGE_PORT=8765
# PI_BRIDGE_TOKEN=
# PI_BINARY=pi
# PI_BRIDGE_PROJECTION_RECENT_DAYS=5
# PI_BRIDGE_SESSION_DIR=/Users/you/.pi/agent/sessions/owui-sessions
# PI_BRIDGE_WORKSPACE_DIR=/Users/you/.pi/owui-bridge-workspace
